# Variables consommées par docker-compose.edge.yml + docker-compose.prod.yml.
# En production, ces valeurs vivent uniquement dans les secrets de l'Environment
# GitHub "production" (jamais dans un fichier .env commité ou présent en clair
# sur le serveur) — voir docs/job-tracker-architecture.md section 13.

MONGO_ROOT_USERNAME=
MONGO_ROOT_PASSWORD=
MONGODB_DB_NAME=job-tracker-prod
WEB_ANGULAR_ORIGIN=https://ng-job-app-tracker.romainh-craft.com

# Cloudflare DDNS (un seul conteneur, partagé entre prod et dev, déployé avec
# l'Environment "production" — liste donc les 6 sous-domaines, pas seulement
# ceux de prod).
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_DOMAINS=next-job-app-tracker.romainh-craft.com,api-job-app-tracker.romainh-craft.com,ng-job-app-tracker.romainh-craft.com,dev.next-job-app-tracker.romainh-craft.com,dev.api-job-app-tracker.romainh-craft.com,dev.ng-job-app-tracker.romainh-craft.com
