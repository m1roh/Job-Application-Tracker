{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "noEmit": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": ["node", "jest"],
    "paths": {
      "@job-tracker/core/*": ["../../packages/core/src/*"],
      "@job-tracker/infrastructure/*": ["../../packages/infrastructure/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
