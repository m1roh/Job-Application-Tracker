# Variables consommées par docker-compose.dev.yml.
# En environnement dev déployé (branche `develop`), ces valeurs vivent
# uniquement dans les secrets de l'Environment GitHub "development" — voir
# docs/job-tracker-architecture.md section 13.

MONGO_ROOT_USERNAME=
MONGO_ROOT_PASSWORD=
MONGODB_DB_NAME=job-tracker-dev
WEB_ANGULAR_ORIGIN=https://dev.ng-job-app-tracker.romainh-craft.com
